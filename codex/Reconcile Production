def main() -> int:
    parser = argparse.ArgumentParser(description="Ensure production-reporting mines exist in project_locations.")
    parser.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="SQLite database path")
    args = parser.parse_args()

    db = connect(args.db_path)
    try:
        ensure_schema(db)
        count = reconcile(db)
    finally:
        db.close()

    print(f"Inserted or updated {count} production-derived project location rows")
    return 0


