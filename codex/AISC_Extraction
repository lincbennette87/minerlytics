def parse_aisc_metrics_to_sqlite(
    *,
    db_path: str | Path,
    symbol: str | None = None,
    accession_number: str | None = None,
    forms: set[str] | None = None,
    latest_per_form: bool = False,
    user_agent: str | None = None,
) -> int:
    db = connect(db_path)
    try:
        ensure_schema(db)
        filings = _select_filings(
            db,
            symbol=symbol,
            accession_number=accession_number,
            forms=forms or DEFAULT_FORMS,
            latest_per_form=latest_per_form,
        )
    finally:
        db.close()

    total = 0
    for filing in filings:
        if not filing["sec_primary_document_url"]:
            continue
        try:
            text = html_to_text(fetch_sec_document_text(filing["sec_primary_document_url"], user_agent=user_agent))
        except Exception:
            continue
        records = extract_aisc_metrics(filing, text)
        total += store_aisc_metrics(db_path=db_path, records=records)
    return total


def extract_aisc_metrics(filing: Any, text: str) -> list[AiscMetric]:
    lines = text.splitlines()
    records: list[AiscMetric] = []
    for index, line in enumerate(lines):
        signal_type = _signal_type(lines, index)
        if not signal_type:
            continue
        if _looks_like_toc_line(line):
            continue

        context_lines = lines[max(0, index - 5) : index + 7]
        context_text = " | ".join(context_lines)
        metal = _metal_from_context(context_text)
        numbers = _candidate_values(_value_text(lines, index), metal=metal)
        if not numbers:
            continue

        metric_label = _metric_label(line, prior_lines=lines[max(0, index - 4) : index], signal_type=signal_type)
        mine_name = _mine_name_from_context(context_lines)
