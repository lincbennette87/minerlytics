#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parents[1]
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

from minerlytics.connectors.aisc_parser import DEFAULT_FORMS, parse_aisc_metrics_to_sqlite
from minerlytics.database import DEFAULT_DB_PATH, active_miner_symbols, connect


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Parse AISC/all-in sustaining cost references from SEC annual and interim reports."
    )
    parser.add_argument("symbols", nargs="*", help="Ticker symbols to parse, for example CDE HL NEM")
    parser.add_argument("--all-miners", action="store_true", help="Parse every active miner")
    parser.add_argument("--forms", nargs="*", default=sorted(DEFAULT_FORMS), help="SEC forms to parse")
    parser.add_argument("--latest-per-form", action="store_true", help="Only parse the latest filing per symbol/form")
    parser.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="SQLite database path")
    parser.add_argument(
        "--user-agent",
        default=os.environ.get("SEC_USER_AGENT"),
        help="SEC-required User-Agent, for example 'Minerlytics admin@example.com'",
    )
    args = parser.parse_args()

    if args.all_miners:
        db = connect(args.db_path)
        try:
            symbols = active_miner_symbols(db)
        finally:
            db.close()
    else:
        symbols = [symbol.upper() for symbol in args.symbols]

    if not symbols:
        parser.error("provide one or more symbols, or use --all-miners")

    total = 0
    forms = {form.upper() for form in args.forms}
    for symbol in symbols:
        count = parse_aisc_metrics_to_sqlite(
            db_path=args.db_path,
            symbol=symbol,
            forms=forms,
            latest_per_form=args.latest_per_form,
            user_agent=args.user_agent,
        )
        total += count
        print(f"{symbol}: imported {count} AISC references")

    print(f"Total imported: {total}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())    metric_label: str
