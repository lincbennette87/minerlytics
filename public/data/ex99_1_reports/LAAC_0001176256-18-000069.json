    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exhibit99-1.htm\n<DESCRIPTION>NOTICE OF MEETING AND RECORD DATE\n<TEXT>\n\n<HTML>\n<HEAD>\n   <TITLE>Exhibit 99.1</TITLE>\n</HEAD>\n\n<BODY bgcolor=\"#ffffff\" style=\"font-family: 'Times New Roman';font-size: 10pt;\">\n\n<A name=\"page_1\"></A>\n\n<a name=\"_bclPageBorder1\"></a>\n\n<DIV style=\"PADDING-LEFT: 0%; PADDING-RIGHT: 0%\">\n\n<HR noshade size=3>\n\n<P style=\"margin-top: 0px; TEXT-ALIGN: right\"><B>Exhibit 99.1</B></P>\n\n<DIV align=left>\n\n<TABLE style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman'; WIDTH: 100%\" cellSpacing=0 border=0>\n\n\n\n<TR>\n\n   <TD width=\"80%\"></TD>\n\n   <TD width=\"20%\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD width=\"80%\" noWrap align=left>&nbsp;</TD>\n\n   <TD width=\"20%\" noWrap align=left>\n   <IMG border=0 src=\"exhibit99-1x1x1.jpg\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD width=\"80%\" noWrap align=left>Date: April 23, 2018</TD>\n\n   <TD width=\"20%\" noWrap align=left>510 Burrard St, 3rd Floor</TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD width=\"80%\" noWrap align=left>&nbsp;</TD>\n\n   <TD width=\"20%\" noWrap align=left>Vancouver BC, V6C 3B9</TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD width=\"80%\" noWrap align=left>&nbsp;</TD>\n\n   <TD width=\"20%\" noWrap align=left>www.computershare.com</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\">To: All Canadian Securities Regulatory Authorities</P>\n\n<P style=\"TEXT-ALIGN: justify\"><B>Subject: LITHIUM AMERICAS CORP.</B></P>\n\n<P style=\"TEXT-ALIGN: justify\">Dear Sir/Madam:</P>\n\n<P style=\"TEXT-ALIGN: justify\">We advise of the following with respect to the upcoming Meeting of Security Holders for the subject Issuer:</P>\n\n<DIV align=left>\n\n<TABLE style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman'; WIDTH: 100%\" cellSpacing=0 border=0>\n\n\n\n<TR>\n\n   <TD style=\"WIDTH: 50%\"></TD>\n\n   <TD style=\"WIDTH: 50%\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BACKGROUND-C