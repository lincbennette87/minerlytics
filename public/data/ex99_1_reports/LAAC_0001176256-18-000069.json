<TR vAlign=bottom>\n\n   <TD style=\"WIDTH: 50%; BACKGROUND-COLOR: #e6efff\" noWrap align=left>\n\n   <P style=\"MARGIN-LEFT: 4%\">NAA for Beneficial Holders</P></TD>\n\n   <TD style=\"WIDTH: 50%; BACKGROUND-COLOR: #e6efff\" noWrap align=left>Yes</TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"WIDTH: 50%\" noWrap align=left>\n\n   <P style=\"MARGIN-LEFT: 4%\">Beneficial Holders Stratification Criteria:</P></TD>\n\n   <TD style=\"WIDTH: 50%\" noWrap align=left>Not Applicable</TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"WIDTH: 50%; BACKGROUND-COLOR: #e6efff\" noWrap align=left>\n\n   <P style=\"MARGIN-LEFT: 4%\">NAA for Registered Holders</P></TD>\n\n   <TD style=\"WIDTH: 50%; BACKGROUND-COLOR: #e6efff\" noWrap align=left>Yes</TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"WIDTH: 50%\" noWrap align=left>\n\n   <P style=\"MARGIN-LEFT: 4%\">Registered Holders Stratification Criteria:</P></TD>\n\n   <TD style=\"WIDTH: 50%\" noWrap align=left>Not Applicable</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\"><B>Voting Security Details:</B></P>\n\n<DIV align=left>\n\n<TABLE style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman'; WIDTH: 100%\" cellSpacing=0 border=0>\n\n\n\n<TR>\n\n   <TD style=\"WIDTH: 33%\"></TD>\n\n   <TD style=\"WIDTH: 33%\"></TD>\n\n   <TD style=\"WIDTH: 33%\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"WIDTH: 33%\" noWrap align=left><B>Description</B></TD>\n\n   <TD style=\"WIDTH: 33%\" noWrap align=left><B>CUSIP Number</B></TD>\n\n   <TD style=\"WIDTH: 33%\" noWrap align=left><B>ISIN</B></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BACKGROUND-COLOR: #e6efff\" width=\"33%\" noWrap align=left>COMMON CLASS</TD>\n\n   <TD style=\"BACKGROUND-COLOR: #e6efff\" width=\"33%\" noWrap align=left>53680Q207</TD>\n\n   <TD style=\"BACKGROUND-COLOR: #e6efff\" width=\"33%\" noWrap align=left>CA53680Q2071</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\">Sincerely,</P>\n\n<P style=\"TEXT-ALIGN: justify\"><B><FONT color=#660066>