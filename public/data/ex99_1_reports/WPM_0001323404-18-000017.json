    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>ex991.htm\n<DESCRIPTION>NEWS RELEASE FOR WHEATON PRECIOUS METALS\n<TEXT>\n<html>\n<head>\n<title></title>\n<!--Licensed to: Silver Wheaton\n    Document created using EDGARfilings PROfile 4.4.0.0\n    Copyright 1995 - 2018 Broadridge-->\n</head>\n<body style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif\" bgcolor=\"#ffffff\" text=\"#000000\">\n<div>\n<hr style=\"BORDER-TOP: medium none; HEIGHT: 4px; BORDER-RIGHT: medium none; BORDER-BOTTOM: medium none; COLOR: #000000; TEXT-ALIGN: center; MARGIN-LEFT: auto; BORDER-LEFT: medium none; BACKGROUND-COLOR: #000000; MARGIN-RIGHT: auto\" align=\"center\" noshade=\"noshade\">\n<br>\n<div style=\"TEXT-ALIGN: left\"><img style=\"HEIGHT: 47px; WIDTH: 287px\" src=\"image0.jpg\"></div>\n\n<div><br>\n</div>\n\n<div><br>\n</div>\n\n<div><br>\n</div>\n\n<table id=\"z6b1b8ac6b67e4e34a722f0018daffd11\" style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; WIDTH: 100%\" cellspacing=\"0\" cellpadding=\"0\">\n<tr>\n<td style=\"WIDTH: 52.72%; VERTICAL-ALIGN: top\">\n<div style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; TEXT-ALIGN: justify\">FOR IMMEDIATE RELEASE</div>\n</td>\n<td style=\"WIDTH: 47.28%; VERTICAL-ALIGN: top\">\n<div style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; TEXT-ALIGN: right\">TSX: WPM</div>\n</td>\n</tr>\n\n<tr>\n<td style=\"WIDTH: 52.72%; VERTICAL-ALIGN: top\">\n<div style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; TEXT-ALIGN: justify\">May 11, 2018</div>\n</td>\n<td style=\"WIDTH: 47.28%; VERTICAL-ALIGN: top\">\n<div style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; TEXT-ALIGN: right\">NYSE: WPM</div>\n</td>\n</tr>\n</table>\n\n<div><br>\n</div>\n\n<div><br>\n</div>\n\n<div style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman', Times, serif; FONT-WEIGHT: bold; TEXT-ALIGN: center\">WHEATON PRECIOUS METALS ANNOUNCES ELECTION<font st