    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exhibit991.htm\n<DESCRIPTION>NEWS RELEASE DATED JANUARY 28, 2008\n<TEXT>\n<!doctype html public \"-//IETF//DTD HTML//EN\">\n<HTML>\n<HEAD>\n<TITLE>Filed by EDF Electronic Data Filing Inc. (604) 879-9956 - Silver Wheaton - Exhibit 99.1</TITLE>\n<META NAME=\"author\" CONTENT=\"Katie Pikor\">\n<META NAME=\"date\" CONTENT=\"01/28/2008\">\n</HEAD>\n<BODY style=\"line-height:12pt; font-family:Times New Roman; font-size:10pt; color:#000000\">\n<P style=\"margin:0px; padding-top:4px; border-top:3px solid #3F3F3F\" align=right><b>Exhibit 99.1<BR>\n</b></P>\n<P style=\"margin:0px; font-family:Arial\" align=center><FONT FACE=\"Arial\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<img src=\"exhibit991001.jpg\" alt=\"[exhibit991001.jpg]\" align=middle height=135.733 width=593.467></FONT></P>\n<P style=\"margin:0px\"><BR></P>\n<P style=\"margin:0px\"><BR></P>\n<TABLE style=\"font-size:13.333px\" cellspacing=0><TR><TD width=780></TD><TD width=340></TD><TD width=340></TD></TR>\n<TR><TD valign=top width=780><P style=\"line-height:18.667px; margin:0px; padding-right:-48px; font-family:Arial; font-size:16px\" align=justify>FOR IMMEDIATE RELEASE</P>\n</TD><TD valign=top width=340><P style=\"font-size:2pt\">&nbsp;</P></TD><TD valign=top width=340><P style=\"line-height:18.667px; margin:0px; padding-right:-48px; font-family:Arial; font-size:16px\">TSX:SLW &nbsp;&nbsp;&nbsp;&nbsp;</P>\n</TD></TR>\n<TR><TD valign=top width=780><P style=\"line-height:18.667px; margin:0px; padding-right:-43.2px; font-family:Arial; font-size:16px\" align=justify>January 28, 2008</P>\n</TD><TD valign=top width=340><P style=\"font-size:2pt\">&nbsp;</P></TD><TD valign=top width=340><P style=\"line-height:18.667px; margin:0px; padding-right:-43.2px; font-family:Arial; font-size:16px\">NYSE:SLW</P>\n</TD></TR>\n</TABLE>\n<P style=\"margin:0px\" align=justify><BR></P>\n<P style=\"margin:0px\" align=center><BR></P>\n<P style=\"line-height:18.667px; ma