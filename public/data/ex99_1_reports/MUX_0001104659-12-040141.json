    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>a12-12803_2ex99d1.htm\n<DESCRIPTION>EX-99.1\n<TEXT>\n\n\n<html>\n<head>\n\n  </head>\n<body lang=\"EN-US\">\n<div style=\"font-family:Times New Roman;\">\n<p align=\"right\" style=\"margin:0in 0in .0001pt;text-align:right;\"><b><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;font-weight:bold;\">Exhibit 99.1</font></b></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">&nbsp;</font></p>\n<table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" width=\"100%\" style=\"border-collapse:collapse;width:100.0%;\">\n<tr>\n<td width=\"75%\" valign=\"top\" style=\"padding:0in 0in 0in 0in;width:75.88%;\">\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\"><img width=\"288\" height=\"69\" src=\"g128032mm01i001.jpg\"></font></p>    </td>\n<td width=\"24%\" valign=\"bottom\" style=\"padding:0in 0in 0in 0in;width:24.12%;\">\n<p align=\"right\" style=\"margin:0in 0in .0001pt;text-align:right;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">May&nbsp;25, 2012</font></p>    </td>   </tr>  </table>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">&nbsp;</font></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">Dear McEwen Mining Shareholders,</font></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">&nbsp;</font></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">Please find below the El Gallo Complex development update.</font></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt;\">&nbsp;</font></p>\n<p style=\"margin:0in 0in .0001pt;\"><font size=\"2\" face=\"Times New Roman\" style=\"font-size:10.0pt