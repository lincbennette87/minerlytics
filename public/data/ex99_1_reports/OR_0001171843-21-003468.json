tr><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; vertical-align: middle ; \">Charles E. Page</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: middle ; \">119,324,317</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: middle ; \">99.85</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: middle ; \">184,920</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: middle ; \">0.15</td></tr><tr><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; vertical-align: middle ; \">Sean Roosen</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: bottom ; \">116,817,055</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: bottom ; \">97.75</td><td style=\"border-top: solid black 1pt ; border-right: solid black 1pt ; border-bottom: solid black 1pt ; border-left: solid black 1pt ; text-align: center ;  vertical-align: middle; vertical-align: bottom ; \">2,692,182</td><td style=\"border-top: solid black 1pt ; border-