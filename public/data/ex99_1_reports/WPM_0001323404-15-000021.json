    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exhibit99-1.htm\n<DESCRIPTION>EXHIBIT 99.1\n<TEXT>\n<html>\n<head>\n    <title>exhibit99-1.htm</title>\n    <!--Licensed to: Silver Wheaton-->\n    <!--Document Created using EDGARizer 2020 5.5.1.0-->\n    <!--Copyright 1995 - 2015 Summit Financial Printing. All rights reserved.-->\n</head>\n<body bgcolor=\"#ffffff\" style=\"FONT-SIZE: 10pt; FONT-FAMILY: Times New Roman; DISPLAY: inline\">\n<div style=\"MARGIN-LEFT: 0pt; DISPLAY: block; MARGIN-RIGHT: 0pt; TEXT-INDENT: 0pt\" align=\"left\"><img src=\"logo.jpg\" alt=\"\"></div>\n\n<div style=\"DISPLAY: block; TEXT-INDENT: 0pt\"><br>\n</div>\n\n<div style=\"DISPLAY: block; TEXT-INDENT: 0pt\"><br>\n</div>\n\n<div style=\"DISPLAY: block; TEXT-INDENT: 0pt\"><br>\n</div>\n\n<div style=\"DISPLAY: block; TEXT-INDENT: 0pt\"><br>\n</div>\n\n<div>\n<table cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; FONT-SIZE: 10pt; FONT-FAMILY: times new roman\">\n<tr>\n<td valign=\"top\" width=\"36%\">\n<div style=\"MARGIN-LEFT: 0pt; DISPLAY: block; MARGIN-RIGHT: 0pt; TEXT-INDENT: 0pt\" align=\"justify\"><font style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; DISPLAY: inline\">FOR IMMEDIATE RELEASE</font></div>\n</td>\n<td align=\"right\" valign=\"top\" width=\"36%\">\n<div style=\"MARGIN-LEFT: 0pt; DISPLAY: block; MARGIN-RIGHT: 0pt; TEXT-INDENT: 0pt\" align=\"right\"><font style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; DISPLAY: inline\">TSX:SLW</font></div>\n</td>\n</tr><tr>\n<td valign=\"top\" width=\"36%\">\n<div style=\"MARGIN-LEFT: 0pt; DISPLAY: block; MARGIN-RIGHT: 0pt; TEXT-INDENT: 0pt\" align=\"justify\"><font style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; DISPLAY: inline\">May 21, 2015</font></div>\n</td>\n<td align=\"right\" valign=\"top\" width=\"36%\">\n<div style=\"MARGIN-LEFT: 0pt; DISPLAY: block; MARGIN-RIGHT: 0pt; TEXT-INDENT: 0pt\" align=\"right\"><font style=\"FONT-SIZE: 10pt; FONT-