tyle=\"width: 20%; padding-right: 5.03pt; padding-left: 5.03pt; vertical-align: top;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">99.59</p>\n            </td>\n            <td style=\"width: 20%; padding-right: 5.03pt; padding-left: 5.03pt; vertical-align: top;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">585,572</p>\n            </td>\n            <td style=\"width: 20%; vertical-align: top; padding-right: 5.03pt; padding-left: 5.03pt;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">0.41</p>\n            </td>\n        </tr>\n        <tr>\n            <td style=\"width: 20%; vertical-align: top; padding-right: 5.03pt; padding-left: 5.03pt;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">Michael Price</p>\n            </td>\n            <td style=\"width: 20%; padding-right: 5.03pt; padding-left: 5.03pt; vertical-align: top;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">141,242,060</p>\n            </td>\n            <td style=\"width: 20%; padding-right: 5.03pt; padding-left: 5.03pt; vertical-align: top;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">99.59</p>\n            </td>\n            <td style=\"width: 20%; padding-right: 5.03pt; padding-left: 5.03pt; vertical-align: top;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">583,457</p>\n            </td>\n            <td style=\"width: 20%; vertical-align: top; padding-right: 5.03pt; padding-left: 5.03pt;\">\n                <p style=\"text-align: center; margin-top: 0pt; margin-bottom: 0pt;\">0.41</p>\n            </td>\n        </tr>\n        <tr>\n            <td style=\"width: 20%; vertical-align: top; padding-right: 5.03pt; padding-left: 5.03pt;\">\n                <p style=\"text-align: center; margin-top: 0p