    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>eld_ex991.htm\n<DESCRIPTION>ELDORADO GOLD NOTICE OF MEETING AND RECORD DATE\n<TEXT>\n<html><head><title>eld_ex991.htm</title><!--Document created using EDGARMaster--></head><body style=\"TEXT-ALIGN: left; FONT: 10pt times new roman\"><p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; MARGIN: 0px; text-align:right;\"><strong>EXHIBIT 99.1</strong></p> <p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; MARGIN: 0px; text-align:left;\">&nbsp;</p> <table style=\"border-spacing:0;font-size:10pt;width:100%\" cellpadding=\"0\"> <tr style=\"height:15px\"> <td style=\"width:75%;\"> <p style=\"margin:0px\">Date: February 28, 2022</p></td> <td style=\"width:25%;\"> <p style=\"margin:0px\"><img src=\"eld_ex991img2.jpg\"></p> <p style=\"margin:0px\">510 Burrard St, 3rd Floor</p> <p style=\"margin:0px\">Vancouver&nbsp;BC, V6C 3B9</p> <p style=\"margin:0px\">www.computershare.com </p></td></tr></table> <p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; MARGIN: 0px; text-align:left;\">&nbsp;</p> <table style=\"border-spacing:0;text-align:left;font:10pt times new roman;width:100%\" cellpadding=\"0\"> <tr style=\"height:15px\"> <td style=\"width:4%;vertical-align:top;\"> <p style=\"margin:0px\">To:</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Each Securities Commission or Securities Regulatory Authority in each of the Provinces of Canada</p></td></tr> <tr style=\"height:15px\"> <td> <p style=\"margin:0px;text-indent:30px\">&nbsp;</p></td> <td> <p style=\"margin:0px\">Toronto Stock Exchange </p></td></tr></table> <p style=\"font-size:10pt;font-family:times new roman;margin:0px\">&nbsp; </p> <p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; MARGIN: 0px; text-align:left;\"><strong>Subject: ELDORADO GOLD CORPORATION</strong></p> <p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times new roman; MARGIN: 0px; text-align:left;\">&nbsp;</p> <p style=\"FONT-SIZE: 10pt; FONT-FAMILY: times ne