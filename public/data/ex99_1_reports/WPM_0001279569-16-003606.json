solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">97.72%</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">4,922,580</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">2.28%</FONT></TD></TR>\n<TR STYLE=\"vertical-align: bottom\">\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; border-left: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">R. Peter Gillin</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">182,011,933</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">84.34%</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">33,802,779</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">15.66%</FONT></TD></TR>\n<TR STYLE=\"vertical-align: bottom\">\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; border-left: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">Chantal Gosselin</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">214,659,697</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">99.46%</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">1,155,015</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">0.54%</FONT></TD></TR>\n<TR STYLE=\"vertical-align: bottom\">\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; border-left: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">Douglas M. Holtby</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">214,499,459</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">99.39%</FONT></TD>\n    <TD NOWRAP STYLE=\"border-right: Black 1pt solid; border-bottom: Black 1pt solid; padding-right: 5.4pt; padding-left: 5.4pt; text-align: center\"><FONT STYLE=\"font-family: Arial, Helvetica, Sans-Serif\">1,315,25