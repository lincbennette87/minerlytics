    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exhibit991.htm\n<DESCRIPTION>NEWS RELEASE DATED APRIL 8, 2008\n<TEXT>\n<!doctype html public \"-//IETF//DTD HTML//EN\">\n<HTML>\n<HEAD>\n<TITLE>Exhibit 99.1</TITLE>\n<META NAME=\"author\" CONTENT=\"Katie Pikor\">\n<META NAME=\"date\" CONTENT=\"04/09/2008\">\n</HEAD>\n<BODY style=\"line-height:12pt; font-family:Times New Roman; font-size:10pt; color:#000000\">\n<hr align=\"center\" width=\"100%\" noshade=\"noshade\" size=\"3\" />\n<P style=\"margin:0px\" align=right><B>Exhibit 99.1</B></P>\n<P style=\"margin:0px\" align=center>&nbsp;</P>\n<P style=\"margin:0px\" align=center><img src=\"exhibit991001.jpg\" alt=\"[exhibit991001.jpg]\" align=middle height=135.733 width=593.467></P>\n<P style=\"margin:0px\"><BR></P>\n<P style=\"margin:0px\"><BR></P>\n<TABLE style=\"font-size:10pt\" cellspacing=0><TR height=0 style=\"font-size:0\"><TD width=730></TD><TD width=730></TD></TR>\n<TR><TD valign=top width=730><P style=\"line-height:14pt; margin:0px; padding-right:-48px; font-family:Arial; font-size:12pt\" align=justify>FOR IMMEDIATE RELEASE</P>\n</TD><TD valign=top width=730><P style=\"line-height:14pt; margin:0px; padding-right:-48px; font-family:Arial; font-size:12pt\" align=right>TSX:SLW</P>\n</TD></TR>\n<TR><TD valign=top width=730><P style=\"line-height:14pt; margin:0px; padding-right:-43.2px; font-family:Arial; font-size:12pt\" align=justify>April 8, 2008</P>\n</TD><TD valign=top width=730><P style=\"line-height:14pt; margin:0px; padding-right:-43.2px; font-family:Arial; font-size:12pt\" align=right>NYSE:SLW</P>\n</TD></TR>\n<TR><TD valign=top width=730><P>&nbsp;</P></TD><TD valign=top width=730><P>&nbsp;</P></TD></TR>\n<TR><TD valign=top width=730><P>&nbsp;</P></TD><TD valign=top width=730><P>&nbsp;</P></TD></TR>\n</TABLE>\n<P style=\"margin:0px\" align=justify><BR></P>\n<P style=\"margin:0px\" align=center><BR></P>\n<P style=\"line-height:14pt; margin:0px; font-family:Arial; font-size:12pt\" align=center><B>