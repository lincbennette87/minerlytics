l;min-width:fit-content;\">Director Nominees</font></p></td>\n    <td style=\"border-top:0.5pt solid #a6a6a6;border-right:0.5pt solid #a6a6a6;padding-left:0.08in;vertical-align:top;border-bottom:0.5pt solid #a6a6a6;padding-right:0.08in;text-align:left;\"><p style=\"font-size:9pt;margin-top:0;font-family:Times New Roman;margin-bottom:0;text-align:center;\"><font style=\"color:#ffffff;white-space:pre-wrap;font-weight:bold;font-family:Arial;min-width:fit-content;\">Votes For</font></p></td>\n    <td style=\"border-top:0.5pt solid #a6a6a6;padding-left:0.08in;vertical-align:top;border-bottom:0.5pt solid #a6a6a6;padding-right:0.08in;text-align:left;\"><p style=\"font-size:9pt;margin-top:0;font-family:Times New Roman;margin-bottom:0;text-align:center;\"><font style=\"color:#ffffff;white-space:pre-wrap;font-weight:bold;font-family:Arial;min-width:fit-content;\">Votes Withheld</font></p></td>\n   </tr>\n   <tr style=\"height:18pt;white-space:pre-wrap;word-break:break-word;\">\n    <td style=\"border-right:0.5pt solid #a6a6a6;padding-left:0.08in;vertical-align:top;border-bottom:0.5pt solid #a6a6a6;padding-right:0.08in;\"><p style=\"font-size:9pt;margin-top:0;font-family:Times New Roman;margin-bottom:0;text-align:left;\"><font style=\"color:#000000;white-space:pre-wrap;font-weight:bold;font-family:Arial;min-width:fit-content;\">Kelvin Dushnisky</font></p><p style=\"font-size:9pt;margin-top:0;font-family:Times New Roman;margin-bottom:0;text-align:left;\"><font style=\"color:#000000;white-space:pre-wrap;font-family:Arial;min-width:fit-content;\"> </font></p></td>\n    <td style=\"border-right:0.5pt solid #a6a6a6;padding-left:0.08in;vertical-align:top;border-bottom:0.5pt solid #a6a6a6;padding-right:0.08in;text-align:left;\"><p style=\"font-size:9pt;margin-top:0;font-family:Times New Roman;margin-bottom:0;text-align:center;\"><font style=\"color:#000000;white-space:pre-wrap;font-family:Arial;min-width:fit-content;\">45,768,333 (95.40%)</font></p></td>\n    <td style=\"padding-left