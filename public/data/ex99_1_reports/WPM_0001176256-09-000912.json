    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exhibit99-1.htm\n<DESCRIPTION>NEWS RELEASE DATED OCTOBER 13, 2009\n<TEXT>\n<!doctype html public \"-//IETF//DTD HTML//EN\">\n<HTML>\n<HEAD>\n<TITLE>Exhibit 99.1</TITLE>\n<META NAME=\"date\" CONTENT=\"MM/DD/YYYY\">\n</HEAD>\n\n<BODY style=\"line-height:12pt; font-family:Times New Roman; font-size:10pt; color:#000000\">\n<hr noshade size=\"3\">\n<P style=\"line-height:11pt; margin:0px; font-size:10pt; font-family:Times New Roman;\" align=right><b>Exhibit 99.1</b></P>\n<P style=\"margin:0px\"><BR></P>\n<P style=\"margin:0px\" align=center><img src=\"slwlogo.jpg\" width=\"581\" height=\"54\"><BR></P>\n<P style=\"margin:0px\"><BR></P>\n<P style=\"margin:0px\"><BR></P>\n<TABLE width=\"100%\" cellspacing=0 style=\"font-size:10pt\"><TR height=0 style=\"font-size:0\"><TD width=50%></TD><TD></TD></TR>\n<TR><TD width=50% valign=top><P style=\"line-height:14pt; margin:0px; padding-right:-1.6px; font-family:Arial; font-size:12pt\" align=justify>FOR IMMEDIATE RELEASE</P>\n</TD><TD valign=top><P style=\"line-height:14pt; margin:0px; padding-right:-1.6px; font-family:Arial; font-size:12pt\" align=right>TSX: SLW</P>\n</TD></TR>\n<TR><TD width=50% valign=top><P style=\"line-height:14pt; margin:0px; padding-right:-48px; font-family:Arial; font-size:12pt\" align=justify>October 13, 2009</P>\n</TD><TD valign=top><P style=\"line-height:14pt; margin:0px; padding-right:-48px; font-family:Arial; font-size:12pt\" align=right>NYSE: SLW</P>\n</TD></TR>\n</TABLE>\n<P style=\"margin:0px\" align=center><BR></P>\n<P style=\"line-height:14pt; margin:0px; padding-right:-0.4px; font-family:Arial; font-size:12pt\" align=center><B>SILVER WHEATON TO RELEASE THIRD QUARTER RESULTS ON</B></P>\n<P style=\"line-height:14pt; margin:0px; padding-right:-0.4px; font-family:Arial; font-size:12pt\" align=center><B>&nbsp;NOVEMBER 9, 2009 </B></P>\n<P style=\"margin:0px\" align=justify><BR></P>\n<P style=\"line-height:13pt; margin:0px; padding-right:-3.2