KGROUND-COLOR: #e6efff\" width=\"20%\" align=center>1,604,448</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>96.60%</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>3.40%</TD>\n</TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"20%\" align=left>Franco Mignacco</TD>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid\" width=\"20%\" align=center>45,754,974</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid\" width=\"20%\" align=center>1,499,958</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid\" width=\"20%\" align=center>96.83%</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid\" width=\"20%\" align=center>3.17%</TD>\n</TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BORDER-LEFT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=left>Gabriel Rubacha</TD>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>43,707,264</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>3,547,668</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>92.49%</TD>\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BACKGROUND-COLOR: #e6efff\" width=\"20%\" align=center>7.51%</TD>\n</TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-RIGHT: #000000 1px solid;