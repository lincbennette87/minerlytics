<p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Vancouver:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">+1 604 638 9010</p> <p style=\"margin:0px\">&nbsp;</p></td></tr> <tr style=\"height:15px\"> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Time:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">11:30 AM ET (8:30 AM PT)</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Toll Free:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">1 800 319 6413</p> <p style=\"margin:0px\">&nbsp;</p></td></tr> <tr style=\"height:15px\"> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Dial in:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">+1 604 638 5340</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Access code:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">0052</p> <p style=\"margin:0px\">&nbsp;</p></td></tr> <tr style=\"height:15px\"> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">Toll free:</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">1 800 319 4610</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">&nbsp;</p> <p style=\"margin:0px\">&nbsp;</p></td> <td style=\"vertical-align:top;\"> <p style=\"margin:0px\">&nbsp;</p> <p style=\"margin:0px\">&nbsp;</p></td></tr></table></p> <p style=\"margin:0px\"></p> <p style=\"font-size:10pt;font-family:times new roman;margin:0px\">&nbsp;</p> <p style=\"font-size:10pt;font-family:times new roman;margin:0px\">The call will be webcast and can be accessed at Eldorado Gold&#8