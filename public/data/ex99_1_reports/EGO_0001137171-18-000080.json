er-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">378,471,064\n        (94.39%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">386,575,580\n        (96.41%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">383,770,480\n        (95.71%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">385,047,154\n        (96.03%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt; color: red\"><FONT STYLE=\"letter-spacing: 0pt\">&nbsp;</FONT></P></TD>\n    <TD STYLE=\"width: 22%; padding-right: 5.4pt; padding-left: 5.4pt\">\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">&nbsp;</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin: 0; letter-spacing: 1pt; text-indent: 0.5in\"><FONT STYLE=\"letter-spacing: 0pt\"><U>Withheld</U></FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin-top: 0; text-align: right; margin-bottom: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">16,506,137\n        (4.12%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin-top: 0; text-align: right; margin-bottom: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">8,643,829\n        (2.16%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin-top: 0; text-align: right; margin-bottom: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">7,445,807\n        (1.86%)</FONT></P>\n        <P STYLE=\"font: 10pt Calibri, Helvetica, Sans-Serif; margin-top: 0; text-align: right; margin-bottom: 0; letter-spacing: 1pt\"><FONT STYLE=\"letter-spacing: 0pt\">9,662,295