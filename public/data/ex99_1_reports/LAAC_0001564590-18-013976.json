    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>lac-ex991_11.htm\n<DESCRIPTION>EX-99.1\n<TEXT>\n<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\" \"http://www.w3.org/TR/html4/loose.dtd\">\n<html>\n<head>\n<title>\nlac-ex991_11.htm\n</title>\n</head>\n<!-- NG Converter v4.0.8.21 -->\n<body>\n\n<p style=\"margin-bottom:0pt;margin-top:0pt;text-indent:0%;font-size:10pt;font-family:Arial;font-weight:normal;font-style:normal;text-transform:none;font-variant: normal;\">&nbsp;</p>\n<p style=\"text-align:right;margin-bottom:12pt;margin-top:0pt;text-indent:0%;font-weight:bold;font-size:11pt;font-family:Arial;font-style:normal;text-transform:none;font-variant: normal;\">Exhibit 99.1</p>\n<p style=\"text-align:center;margin-bottom:12pt;margin-top:0pt;text-indent:0%;font-weight:bold;font-size:11pt;font-family:Arial;font-style:normal;text-transform:none;font-variant: normal;\">ABRIDGEMENT CERTIFICATE</p>\n<div align=\"left\">\n<table border=\"0\" cellspacing=\"0\" cellpadding=\"0\"  style=\"border-collapse:collapse; width:100%;\">\n<tr>\n<td valign=\"top\" style=\"width:7.69%;white-space:nowrap\">\n<p style=\"text-align:justify;margin-bottom:12pt;margin-top:0pt;font-size:11pt;font-family:Arial;font-weight:normal;font-style:normal;text-transform:none;font-variant: normal;\"><font style=\"font-size:11pt;font-family:Arial;font-weight:normal;font-style:normal;text-transform:none;font-variant: normal;\">RE:</font></p></td>\n<td valign=\"top\">\n<p style=\"text-align:justify;margin-bottom:12pt;margin-top:0pt;font-weight:normal;font-style:normal;text-transform:none;font-variant: normal;font-family:Arial;font-size:11pt;\">Annual General Meeting (the &#8220;<font style=\"font-weight:bold;\">Meeting</font>&#8221;) of shareholders of Lithium Americas Corp. (the &#8220;<font style=\"font-weight:bold;\">Corporation</font>&#8221;) scheduled for June 21, 2018</p></td></tr></table></div>\n<p style=\"text-align:justify;margin-bottom:0pt;border-top:Solid 1pt;padding-t