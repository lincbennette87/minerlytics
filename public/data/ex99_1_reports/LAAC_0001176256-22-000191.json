olid\" width=\"50%\" noWrap align=left>Xiaoshen Wang</TD>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>37,188,584 (87.43%)</TD>\n\n   <TD style=\"BORDER-RIGHT: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>5,348,901 (12.57%)</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\"><B>Appointment of the Auditors</B></P>\n\n<DIV align=left>\n\n<TABLE style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman'; WIDTH: 100%\" cellSpacing=0 border=0>\n\n\n\n<TR>\n\n   <TD width=\"50%\"></TD>\n\n   <TD width=\"25%\"></TD>\n\n   <TD width=\"25%\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"50%\" noWrap align=left><B><FONT color=#ffffff>Resolution</FONT></B></TD>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"25%\" noWrap align=center><B><FONT color=#ffffff>Votes For</FONT></B></TD>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"25%\" noWrap align=center><B><FONT color=#ffffff>Votes Withheld</FONT></B></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"50%\" noWrap align=left>Appointing PwC as the auditors</TD>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>72,728,305 (99.24%)</TD>\n\n   <TD style=\"BORDER-RIGHT: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>558,305 (0.76%)</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\"><B>Advisory Vote</B></P>\n\n<DIV align=left>\n\n<TABLE style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Times New Roman'; WIDTH: 100%\" cellSpacing=0 border=0>\n\n\n\n<TR>\n\n   <TD width=\"50%\"></TD>\n\n   <TD width=\"25%\"></TD>\n\n   <TD width=\"25%\"></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"50%\" noWrap align=left><B><FONT color=#ffffff>Resolution</FONT></B></TD>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"25%\" noWrap align=center><B><FONT color=#ffffff>Votes For</FONT></B></TD>\n\n   <TD style=\"BORDER-TOP: #000000 1px solid; BORDER-RIGHT: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" bgColor=#933447 width=\"25%\" noWrap align=center><B><FONT color=#ffffff>Votes Against</FONT></B></TD></TR>\n\n<TR vAlign=bottom>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"50%\" noWrap align=left>Advisory Vote on Executive Compensation</TD>\n\n   <TD style=\"BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>40,915,602 (96.19%)</TD>\n\n   <TD style=\"BORDER-RIGHT: #000000 1px solid; BORDER-BOTTOM: #000000 1px solid; BORDER-LEFT: #000000 1px solid\" width=\"25%\" noWrap align=center>1,621,882 (3.81%)</TD></TR></TABLE></DIV>\n\n<P style=\"TEXT-ALIGN: justify\">Further details concerning voting results are available under the Company&#8217;s profile on SEDAR at <U>www.sedar.com</U>.</P></DIV><BR>\n\n<HR style=\"PAGE-BREAK-AFTER: always\" align=center SIZE=1 width=\"100%\" noShade>\n\n<BR>\n\n<A name=\"page_2\"></A><BR>\n\n<a name=\"_bclPageBorder2\"></a><DIV style=\"PADDING-LEFT: 0%; PADDING-RIGHT: 0%\">\n\n<P style=\"TEXT-ALIGN: justify\"><B><FONT color=#933447>ABOUT LITHIUM AMERICAS</FONT></B></P>\n\n<P style=\"TEXT-ALIGN: justify\">Lithium Americas Corp. is focused 