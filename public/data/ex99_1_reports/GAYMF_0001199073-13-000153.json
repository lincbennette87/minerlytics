    "html": "<DOCUMENT>\n<TYPE>EX-99.1\n<SEQUENCE>2\n<FILENAME>exh99_1.htm\n<DESCRIPTION>EXHIBIT 99.1\n<TEXT>\n<html>\n<head>\n    <title>exh99_1.htm</title>\n    <!--Licensed to: marketwire-->\n    <!--Document Created using EDGARizerAgent 5.4.3.1-->\n    <!--Copyright 1995 - 2009 Thomson Reuters. All rights reserved.-->\n</head>\n<body bgcolor=\"#ffffff\" style=\"DISPLAY: inline; FONT-FAMILY: Times New Roman; FONT-SIZE: 10pt\">\n<div style=\"TEXT-INDENT: 0pt; DISPLAY: block; MARGIN-LEFT: 0pt; MARGIN-RIGHT: 0pt\" align=\"left\">&#160;</div>\n\n<div>\n<hr style=\"MARGIN-TOP: -5px; COLOR: #000000\" noshade size=\"4\">\n<hr style=\"MARGIN-TOP: -10px; COLOR: #000000\" noshade size=\"1\">\n</div>\n\n<div style=\"TEXT-ALIGN: right\"><font style=\"FONT-WEIGHT: bold\">Exhibit 99.1</font></div>\n\n<div align=\"center\">\n<table bgcolor=\"white\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"FONT-FAMILY: times new roman; FONT-SIZE: 9pt; FONT-SIZE: 9pt; FONT-FAMILY: times new roman\">\n<tr>\n<td valign=\"top\" width=\"50%\"><font style=\"FONT-FAMILY: times new roman; FONT-SIZE: 10pt\"><img src=\"coffeylogo3.jpg\" alt=\"graphic\"></font></td>\n<td width=\"50%\" style=\"TEXT-ALIGN: right\"><font style=\"FONT-FAMILY: times new roman; FONT-SIZE: 10pt\"><img src=\"fiftyyears.jpg\" alt=\"graphic\"></font></td>\n</tr></table>\n</div>\n\n<div>&#160;</div>\n\n<div align=\"center\">\n<table bgcolor=\"white\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"FONT-FAMILY: times new roman; FONT-SIZE: 9pt; FONT-SIZE: 9pt; FONT-FAMILY: times new roman\">\n<tr>\n<td valign=\"top\" width=\"5%\" style=\"TEXT-ALIGN: left\"><font style=\"FONT-FAMILY: times new roman; FONT-SIZE: 10pt\"><font style=\"DISPLAY: inline; FONT-WEIGHT: bold\">TO:</font></font></td>\n<td width=\"1%\"><font style=\"FONT-FAMILY: times new roman; FONT-SIZE: 10pt\">&#160;</font></td>\n<td valign=\"top\" width=\"94%\" style=\"TEXT-ALIGN: left\">\n<div><font style=\"FONT-FAMILY: times new roman; FONT-SIZE